{
    "name": "interaction-design-foundation/psalm-laravel-nova",
    "description": "Psalm plugin for Laravel Nova",
    "license": "MIT",
    "type": "psalm-plugin",
    "keywords": [
        "psalm",
        "psalm-plugin",
        "static analysis",
        "laravel",
        "nova"
    ],
    "require": {
        "php": "^8.4",
        "vimeo/psalm": "^7.0.0-beta19 || dev-master"
    },
    "require-dev": {
        "interaction-design-foundation/coding-standard": "^1.0-RC1",
        "phpunit/phpunit": "^12.5 || ^13.2"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "InteractionDesignFoundation\\PsalmLaravelNova\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InteractionDesignFoundation\\PsalmLaravelNova\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "psalm": {
            "pluginClass": "InteractionDesignFoundation\\PsalmLaravelNova\\Plugin"
        }
    },
    "scripts": {
        "cs": "@cs:fix",
        "cs:fix": [
            "@php-cs-fixer",
            "@phpcbf"
        ],
        "php-cs-fixer": "php-cs-fixer fix --no-interaction --ansi --quiet",
        "phpcbf": "phpcbf -p --colors",
        "phpcs": "phpcs -p -s --colors --report-full --report-summary",
        "psalm": "psalm",
        "test": "phpunit"
    }
}
